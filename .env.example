# Sigma Core OS - environment variables
# Copy to .env and fill in values

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
PORT=3001

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Path to the SQLite database file (default: ./sigma.db)
DB_PATH=./sigma.db

# ---------------------------------------------------------------------------
# LLM - core/llm/index.ts
# ---------------------------------------------------------------------------

# LiteLLM proxy base URL (hosted)
# For hosted LiteLLM:   https://your-litellm-host.example.com/v1
# For OpenAI direct:    https://api.openai.com/v1
# For local Ollama:     http://localhost:11434/v1  (future)
LLM_BASE_URL=https://api.openai.com/v1

# Model name - passed to LiteLLM / OpenAI
# Primary:   gpt-4o
# Fallback:  claude-3-5-sonnet-20241022  (future)
LLM_MODEL=gpt-4o

# API key - required for all LLM calls
# LiteLLM proxy key, or your OpenAI key directly
LLM_API_KEY=sk-...

# Request timeout in milliseconds (default: 30000)
LLM_TIMEOUT_MS=30000

# Max retries on 429 / 5xx errors, with exponential backoff (default: 2)
LLM_MAX_RETRIES=2
